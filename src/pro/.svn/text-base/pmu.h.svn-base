#ifndef ___pmu_H
#define ___pmu_H
#ifdef __cplusplus
extern "C" {
#endif // __cplusplus

#include "Pmu.h"

#define VSIM(s,...)						\
(								\
	{							\
		DcHandle handle	= UTL_GetDcHandle();     	\
		UTL_SetDcMode  ( handle, UT_DCT_VSIM);		\
		UTL_SetDcSource( handle, s          );		\
		__VA_ARGS__;					\
        	UTL_SetDcLimitHigh( handle, 0.000, UT_OFF);     \
        	UTL_SetDcLimitLow ( handle, 0.000, UT_OFF);     \
		UTL_SendDc        ( handle, 1);			\
		UTL_DeleteHandle  ( handle);			\
	}							\
)
#define ISVM(s,...)						\
(								\
	{							\
		DcHandle handle	= UTL_GetDcHandle();     	\
		UTL_SetDcMode  ( handle, UT_DCT_ISVM);		\
		UTL_SetDcSource( handle, s          );		\
		__VA_ARGS__;					\
        	UTL_SetDcLimitHigh( handle, 0.000, UT_OFF);     \
        	UTL_SetDcLimitLow ( handle, 0.000, UT_OFF);     \
		UTL_SendDc        ( handle, 1);			\
		UTL_DeleteHandle  ( handle);			\
	}							\
)
#define MVM(...)						\
(								\
	{							\
		DcHandle handle	= UTL_GetDcHandle();     	\
		UTL_SetDcMode  ( handle, UT_DCT_MVM);		\
		__VA_ARGS__;					\
        	UTL_SetDcLimitHigh( handle, 0.000, UT_OFF);     \
        	UTL_SetDcLimitLow ( handle, 0.000, UT_OFF);     \
		UTL_SendDc        ( handle, 1);			\
		UTL_DeleteHandle  ( handle);			\
	}							\
)

