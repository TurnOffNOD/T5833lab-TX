void	setDutPass(Test_t *test)
{
	char *name;
	asprintf( &name, "%d", test->test_no);
#ifdef  SHOW_TEST_NAME
	asprintf( &name, "%s", test->title);
#endif
	DutCursor	dut_cursor = UTL_GetDutCursor( UT_CDUT );
	UT_DUT		dut;
	while	(( dut = UTL_NextDut( dut_cursor )) != UT_NOMORE)
	{
		UTL_ResetTestResult ( dut, name, UT_RES_FUNC );
	}
	UTL_DeleteCursor( dut_cursor);
	free(name);
}



void    ShowResult( Test_t *test) {
	int     dut_count = UTL_GetDutCount( UT_DDUT);
	int     result[ dut_count+1];
	for ( int dut=1; dut<=dut_count; dut++) result[dut] = '-';

	DutCursor dut_cursor;
	UT_DUT    dut;
	dut_cursor = UTL_GetDutCursor( UT_PDUT); while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) result[ dut-1] = 'P'; UTL_DeleteCursor( dut_cursor);
	dut_cursor = UTL_GetDutCursor( UT_FDUT); while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) result[ dut-1] = 'f'; UTL_DeleteCursor( dut_cursor);

	printf("%4d: %-64s:",test->test_no, test->title);
	dut_cursor = UTL_GetDutCursor( UT_DDUT); while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) printf("%c%s",result[ dut-1],(dut%8)==0?" ":"" ); UTL_DeleteCursor( dut_cursor);
	ShowTime();
}

char	*FormatValue( double var, const char *unit, char *buffer) {
	if      ( (var >= 1.0e-0 ) || (var <= -1.0e-0 ) ) sprintf( buffer, "%6.3f[ %s]", var*1e+0 , unit);
	else if ( (var >= 1.0e-3 ) || (var <= -1.0e-3 ) ) sprintf( buffer, "%6.3f[m%s]", var*1e+3 , unit);
	else if ( (var >= 1.0e-6 ) || (var <= -1.0e-6 ) ) sprintf( buffer, "%6.3f[u%s]", var*1e+6 , unit);
	else if ( (var >= 1.0e-9 ) || (var <= -1.0e-9 ) ) sprintf( buffer, "%6.3f[n%s]", var*1e+9 , unit);
	else if ( (var >= 1.0e-12) || (var <= -1.0e-12) ) sprintf( buffer, "%6.3f[p%s]", var*1e+12, unit);
	else                                              sprintf( buffer, "%6.3f[ %s]", 0.000    , unit);
	return	buffer;
}

void	ShowDpsResult( Test_t *test) {
	char	buffer[16];
	ShowResult( test);
	DctReadPinHandle	dct_read_pin	= UTL_GetDctReadPinHandle();
	UTL_SetDctReadPinType  ( dct_read_pin, UT_PINTYPE_VS);
	UTL_SetDctReadPinMode  ( dct_read_pin, UT_RES_OVERFLOW);
	DutCursor	dut_cursor	= UTL_GetDutCursor( UT_CDUT);
	int		dut;
	while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) {
		UTL_SetDctReadPinDut   ( dct_read_pin, dut);
		PinCursor	pin_cursor	= UTL_GetPinCursor( test->target);
		int		pin;
		while( (pin = UTL_NextPin( pin_cursor)) != UT_NOMORE) {
			UTL_SetDctReadPinNumber( dct_read_pin, pin);
			char	*unit;
			if      ( UTL_ReadDctPinMeasMode( dct_read_pin) == UT_DCT_VSIM ) unit = "A";
			else                                                             unit = "V";
			if ( UTL_ReadDctPin( dct_read_pin) == UT_ON ) printf("P%-4d: ---- \n", pin);
			else                                          printf("P%-4d:%s\n"  , pin, FormatValue( UTL_ReadDctPinData( dct_read_pin), unit, buffer));
		}
		UTL_DeleteCursor( pin_cursor);
	}
	UTL_DeleteCursor( dut_cursor);
	UTL_DeleteHandle( dct_read_pin);
}

void	ShowPmuResult( Test_t *test) {
	char	buffer[16];
	ShowResult( test);
	DctReadPinHandle	dct_read_pin	= UTL_GetDctReadPinHandle();
	UTL_SetDctReadPinType  ( dct_read_pin, UT_PINTYPE_PIN);
	UTL_SetDctReadPinMode  ( dct_read_pin, UT_RES_OVERFLOW);
	DutCursor	dut_cursor	= UTL_GetDutCursor( UT_CDUT);
	int		dut;
	while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) {
		UTL_SetDctReadPinDut   ( dct_read_pin, dut);
		PinCursor	pin_cursor	= UTL_GetPinCursor( test->target);
		int		pin;
		while( (pin = UTL_NextPin( pin_cursor)) != UT_NOMORE) {
			UTL_SetDctReadPinNumber( dct_read_pin, pin);
			char	*unit;
			if      ( UTL_ReadDctPinMeasMode( dct_read_pin) == UT_DCT_VSIM ) unit = "A";
			else                                                             unit = "V";
			if ( UTL_ReadDctPin( dct_read_pin) == UT_ON ) printf("P%-4d: ---- \n", pin);
			else                                          printf("P%-4d:%s\n"  , pin, FormatValue( UTL_ReadDctPinData( dct_read_pin), unit, buffer));
		}
		UTL_DeleteCursor( pin_cursor);
	}
	UTL_DeleteCursor( dut_cursor);
	UTL_DeleteHandle( dct_read_pin);
}

void	FailReject( Test_t *test) {
	ShowResult( test);
	DutCursor dut_cursor;
	UT_DUT    dut;
	dut_cursor = UTL_GetDutCursor( UT_FDUT); while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) UTL_SetRejection( dut, UT_OFF)                                            ; UTL_DeleteCursor( dut_cursor);
}
