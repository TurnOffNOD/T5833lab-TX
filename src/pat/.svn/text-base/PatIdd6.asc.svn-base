		                                   :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;
		NOP                              I :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;
		                                   :    ,     ,    ,     ,   ,   ,      ,BANK_XA,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;
		                                   :    ,CYP7 ,    ,     ,CS0,   ,SRE1  ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;   
		                                   :    ,CYP7 ,    ,     ,   ,   ,SRE2  ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;   
   		IDXI2 1				 I :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 1  9  17		tSR = 15nS = 24 CK  
						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 2  10 18                           
						   :    ,     ,    ,     ,   ,   ,	,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 3  11 19                         
						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 4  12 20
   		IDXI2 1				 I :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 5  13 21
						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 6  14 22
   						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 7  15 23
   						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ; 8  16 24
LP0:		NOP                              I :    ,CYP7 ,CKEL,CKSTP,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,CKSTP,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,       ,   ,   ,    ,     ,             ;   
