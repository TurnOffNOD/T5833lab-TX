MPAT	PatIdd3p<4WAY>
	MODE MUX TP2INV REFRESHB
	RDX	10
	REGISTER
		ISP	= REF	; Refresh
	INSERT patSdef
START	#0
;		                                    TSn  CYPn ,CKEL,CKOFF,CS0,CS1,CMD   ,BANK   ,X   ,XC<XC+1 ,CMD  ,BANK   ,Y   ,YC<YC+D4,DQSR,DQSHL,R,TP     ,/D1,/D2,DM00,ODT  ,            ;
		JSR POWERUP                             ,     ,CKEL,     ,   ,   ,RESET ,       ,    ,        ,     ,       ,    ,        ,    ,     , ,       ,   ,   ,    ,     ,             ;
		NOP                              T      ,     ,    ,     ,   ,   ,      ,       ,    ,        ,     ,       ,    ,        ,    ,     , ,       ,   ,   ,    ,     ,             ;
		JSR IDD3P                               ,     ,    ,     ,   ,   ,      ,       ,    ,        ,     ,       ,    ,        ,    ,     , ,       ,   ,   ,    ,     ,             ;
		STPS
	
	
;################################ IDD2P Idle Power-down Standby Current      ################################
;		                                    TSn ,CYPn ,CKEL,CKOFF,CS0,CS1,CMD   ,BANK   ,X   ,XC<XC+1 ,CMD  ,BANK   ,Y   ,YC<YC+D4,DQSR,DQSHL,R,TP             ,/D1,/D2,DM00,ODT  ,             ;
IDD3P:		NOP                                :    ,     ,	   ,     ,   ,   ,      ,       ,X<XC,XC<0    ,     ,       ,Y<YC,YC<0    ,    ,     , ,TP<TPH TP2<TPH2,   ,   ,    ,     ,             ;
		                                   :    ,     ,	   ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,	   ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		NOP                                :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
		                                   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
   		NOP				 I :    ,     ,    ,     ,   ,   ,      ,BANK_XA,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;  
						   :    ,CYP2 ,    ,     ,CS0,   ,ACT11 ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;  
						   :    ,CYP4 ,    ,     ,   ,   ,ACT12 ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;  
						   :    ,CYP5 ,    ,     ,CS0,   ,ACT21 ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;  
   		NOP				 I :    ,CYP6 ,    ,     ,   ,   ,ACT22 ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;  
						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ; 1	tCMDCKE = 1.75nS = 3 CK 
   						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ; 2 
   						   :    ,     ,    ,     ,   ,   ,      ,	,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ; <3> 
LP0:		NOP				 I :    ,CYP7 ,CKEL,     ,   ,   ,R1    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,     ,   ,   ,R2    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,     ,   ,   ,R3    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,     ,   ,   ,R4    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
		JMP LP0				 I :    ,CYP7 ,CKEL,     ,   ,   ,R5    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,     ,   ,   ,R6    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,     ,   ,   ,R7    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
				   		   :    ,CYP7 ,CKEL,     ,   ,   ,R8    ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;   
		RTN				   :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,	   ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,	   ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
		                                   :    ,     ,    ,     ,   ,   ,      ,       ,X<XC,        ,     ,       ,Y<YC,        ,    ,     , ,               ,   ,   ,    ,     ,             ;
	INSERT patPowerUp
	INSERT patRefresh
END
