static inline	void	setCategory( Test_t *test) {
	DutCursor dut_cursor;
	UT_DUT    dut;
	if ( test->pass_category > 0 ) { dut_cursor = UTL_GetDutCursor( UT_PDUT); while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) UTL_SetCategory( dut, test->pass_category); UTL_DeleteCursor( dut_cursor); }
	if ( test->fail_category > 0 ) { dut_cursor = UTL_GetDutCursor( UT_FDUT); while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) UTL_SetCategory( dut, test->fail_category); UTL_DeleteCursor( dut_cursor); }
}
static	inline	void	patMeas ( Test_t *test) {
	FctHandle	fct	= UTL_GetFctHandle();
	UTL_SetFctMpatName ( fct, (char *)test->pattern_name);
//	UTL_SetFctStartPc  ( fct, 0);
	UTL_SetFctStartPc  ( fct, test->start_pc);
	UTL_SetFctNoWait   ( fct, UT_OFF);
	UTL_SetFctNoClear  ( fct, UT_ON );
	UTL_MeasFct        ( fct );
	UTL_DeleteHandle   ( fct );
}
static	inline	void	patStart( Test_t *test) {
	FctHandle	fct	= UTL_GetFctHandle();
	UTL_SetFctMpatName ( fct, (char *)test->pattern_name);
//	UTL_SetFctStartPc  ( fct, 0);
	UTL_SetFctStartPc  ( fct, test->start_pc);
	UTL_SetFctNoWait   ( fct, UT_ON );
	UTL_SetFctNoClear  ( fct, UT_ON );
	UTL_StartFct       ( fct );
	UTL_DeleteHandle   ( fct );
}
static	inline	void    patStop ( void ) { UTL_StopFct (); }
static	inline	void	PmuMeas( const char *pinlist_name, int count, double upper, double lower) {
	DcHandle	dc	= UTL_GetDcHandle();
	UTL_UpdateDc      ( dc, 1);
	UTL_SetDcMeasCnt  ( dc, count);
	UTL_SetDcLimitHigh( dc, (isnan(upper)?0.000:upper), (isnan(upper)?UT_OFF:UT_ON));
	UTL_SetDcLimitLow ( dc, (isnan(lower)?0.000:lower), (isnan(lower)?UT_OFF:UT_ON));
	UTL_SendDc        ( dc, 1);
	UTL_DeleteHandle  ( dc);

	DcHandle	dct	= UTL_GetDctHandle();
	UTL_SetDctPinList( dct, (char *)pinlist_name);
	UTL_MeasDct      ( dct);
	UTL_DeleteHandle ( dct);
}
static	inline	void	DpsMeas( const char *vslist_name, int count, double upper, double lower) {
	PinCursor	pin_cursor	= UTL_GetPinCursor( (char *)vslist_name);
	UT_PIN		pin		= UTL_NextPin( pin_cursor);
	UTL_DeleteCursor( pin_cursor);

	VsHandle	vs	= UTL_GetVsHandle();
	UTL_UpdateVs      ( vs, pin);
	UTL_SetVsMeasCnt  ( vs, count);
	UTL_SetVsLimitHigh( vs, (isnan(upper)?0.000:upper), (isnan(upper)?UT_OFF:UT_ON));
	UTL_SetVsLimitLow ( vs, (isnan(lower)?0.000:lower), (isnan(lower)?UT_OFF:UT_ON));
	UTL_SendVs        ( vs, pin);
	UTL_DeleteHandle  ( vs);

	DcHandle	dct	= UTL_GetDctHandle();
	UTL_SetDctPinList( dct, (char *)vslist_name);
	UTL_MeasDct      ( dct);
	UTL_DeleteHandle ( dct);
}
static	inline	void	addrScram(  Test_t *test) {
	AddrScramHandle	addr_scram	= UTL_GetAddrScramHandle();
	if ( test->scram_name == NULL ) UTL_SetAddrScramMode    ( addr_scram, UT_SCR_DISABLE);
	else {
		UTL_SetAddrScramMode    ( addr_scram, UT_SCR_ENABLE);
		UTL_SetAddrScramFileName( addr_scram, test->scram_name);
	}
	UTL_SendAddrScram       ( addr_scram);
	UTL_DeleteHandle        ( addr_scram);
}
static	inline	void	preScram(  Test_t *test) {
	AddrScramHandle	pre_scram	= UTL_GetAddrScramHandle();
	if ( test->prescram_name == NULL ) UTL_SetAddrScramMode    ( pre_scram, UT_SCR_DISABLE);
	else {
		UTL_SetAddrScramMode    ( pre_scram, UT_SCR_ENABLE);
		UTL_SetAddrScramFileName( pre_scram, test->prescram_name);
	}
	UTL_SendPreScram       ( pre_scram);
	UTL_DeleteHandle        ( pre_scram);
}
static	inline	void	burstScram( Test_t *test) {
	static BurstScramHandle bscr = -1;
	if ( bscr < 0 ) {
		bscr = UTL_GetBurstScramHandle();
		UTL_SetBurstScramMode           ( bscr, UT_ON);
		UTL_SetBurstScramDdrType        ( bscr, 4);
		UTL_SetBurstScramBaseFileName   ( bscr, (char *)"BscrLp");
		UTL_SetBurstScramDataRate       ( bscr, 2);
		UTL_SetBurstScramLength         ( bscr, 16);
		UTL_SetBurstScramWrapType       ( bscr, UT_WPTSQ);
		UTL_AddBurstScramWriteSignal    ( bscr, UT_SIG_WT);
		UTL_SetBurstScramAddrUnit       ( bscr, UT_UNIT_PDS , UT_OFF);
		UTL_SetBurstScramAddrUnit       ( bscr, UT_UNIT_DFM , UT_ON );
		UTL_SetBurstScramAddrUnit       ( bscr, UT_UNIT_FP  , UT_ON );
	}
	UTL_SendBurstScram( bscr);
}

static	inline	void	afmDisable( Test_t *test) {
	static FcmConfigHandle afmhandle = -1;
	if ( afmhandle < 0 ) {
		afmhandle = UTL_GetFcmConfigHandle();
		UTL_AddFcmConfigAction		( afmhandle, 1,	UT_FCM_DISABLE);
//		UTL_AddFcmConfigAction		( afmhandle, 2,	UT_FCM_DISABLE);
	}
	UTL_SendFcmConfig( afmhandle ); 

//	static FcmAccessHandle afmaccess = -1;
//	if ( afmhandle < 0 ) {
//		afmaccess = UTL_GetAccessHandle();
//		UTL_SetFcmAccessAllDut		( afmaccess, UT_ON);
//		UTL_SetFcmAccessAllBit		( afmaccess, UT_ON);
//		UTL_SetFcmAccessPresetAllMemory ( afmaccess, UT_ON);
//	}
//	UTL_PresetFcm( afmaccess, 0 );
}
static	inline	void	ubmDisable( Test_t *test) {
	static UbmConfigHandle ubmhandle = -1;
	if ( ubmhandle < 0 ) {
		ubmhandle = UTL_GetUbmConfigHandle();
		UTL_ClearUbmConfigFunctionSelect	( ubmhandle					);
		UTL_ClearUbmConfigPin			( ubmhandle,	UT_UBM_UNIT_PM			);
		UTL_ClearUbmConfigPin			( ubmhandle,	UT_UBM_UNIT_SCRESULTMEMORY	);
		UTL_ClearUbmConfigPin			( ubmhandle,	UT_UBM_UNIT_EXP			);
	}
	UTL_SendUbmConfig( ubmhandle ); 
}
static	inline	void	ilMode( Test_t *test) {
	IlModeHandle    handle = UTL_GetIlModeHandle();
	UTL_SetIlMode          ( handle,  test->ilway);
	UTL_SendIlMode         ( handle    );
	UTL_DeleteHandle       ( handle    );
}


void	PmuTest( Test_t *test) {
	char *name;
	asprintf( &name, "%d", test->test_no);
	char *caliname;
	asprintf( &caliname, "%d", test->test_no);
	asprintf( &name, "%d", test->test_no);
#ifdef  SHOW_TEST_NAME
	asprintf( &name, "%s", test->title);
#endif
	void    func() {
		if ( test->pattern_name) ilMode( test );
		if ( test->tim) test->tim( test);
		if ( test->lev) test->lev( test);
		if ( test->dps) test->dps( test);
		if ( test->pmu) test->pmu( test);
		if ( test->pin) test->pin( test);
		if ( test->reg) test->reg( test);
		if ( test->afm) test->afm( test); else afmDisable( test );
		if ( test->ubm) test->ubm( test); else ubmDisable( test ); 
		if ( test->pre) test->pre( test);
		if ( test->pattern_name) preScram( test), addrScram( test), burstScram( test);
		fixeddelay_config();
		if ( test->pattern_name) UTL_ExecSbcal( caliname, (char *)"NOPBIDCHK,NOMBTYPECHK,NOMBIDCHK,NOPBLOCKCHK,NOMBLOCKCHK,NOSTATUSCHK");
		UTL_OnPowerSeq();
		UTL_SetWet();
		if ( test->pattern_name) patStart( test);
		UTL_WaitTime( 200 mS);
		PmuMeas  ( test->target, 16, test->upper, test->lower);
		if ( test->pattern_name) patStop ();
		fixeddelay_reset();
		UTL_ResetWet();
		UTL_OffPowerSeq();

		if ( test->pst) test->pst( test);
		setCategory( test);
	}
	TestHandle test_handle = UTL_GetTestHandle();
	UTL_SetTestAction( test_handle, func);
	UTL_Test         ( test_handle, name);
	UTL_DeleteHandle ( test_handle      );
	free(name);
	free(caliname);
}

