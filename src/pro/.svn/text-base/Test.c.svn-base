void	PatTest ( Test_t *test) {
	char *name;
	char *caliname;
	asprintf( &caliname, "%d", test->test_no);
	asprintf( &name, "%d", test->test_no);
#ifdef  SHOW_TEST_NAME
	asprintf( &name, "%s", test->title);
#endif
	void    func() {
		if ( test->pattern_name) ilMode( test );
		if ( test->tim) test->tim( test);
		if ( test->lev) test->lev( test);
		if ( test->dps) test->dps( test);
		if ( test->pmu) test->pmu( test);
		if ( test->pin) test->pin( test);
		if ( test->afm) test->afm( test); else afmDisable( test );
		if ( test->ubm) test->ubm( test); else ubmDisable( test ); 
		if ( test->reg) test->reg( test);
		if ( test->pre) test->pre( test);
		preScram ( test);
		addrScram ( test);
		burstScram( test);
		fixeddelay_config();
		UTL_ExecSbcal( caliname, (char *)"NOPBIDCHK,NOMBTYPECHK,NOMBIDCHK,NOPBLOCKCHK,NOMBLOCKCHK,NOSTATUSCHK");
		UTL_OnPowerSeq();
		UTL_SetWet();
		patMeas( test);
		fixeddelay_reset();
		UTL_ResetWet();
		UTL_OffPowerSeq();
		if ( test->pst) test->pst( test);
		setCategory( test);
	}
	TestHandle test_handle = UTL_GetTestHandle();
	UTL_SetTestAction( test_handle, func);
	UTL_Test         ( test_handle, name);
	UTL_DeleteHandle ( test_handle      );
	free(name);
	free(caliname);
}

void	TestStart(void) {
	UTL_StartTimer         ( UT_TIMER_R10US);
	setlinebuf(stdout);
	printf("-------------------------------------------Test Start-----------------------------------------------------\n");

	// ------------------ only For T5833/32, not support T5503HS2
	MemoryModuleHandle h=UTL_GetMemoryModuleHandle();
	UTL_AddMemoryModulePurpose(h, UT_MEM_FCM, 3);
	UTL_AddMemoryModulePurpose(h, UT_MEM_FBM, 1);
	UTL_SendMemoryModule(h);
	UTL_DeleteHandle(h);

	UTL_SetDctSepaDrCtrlMode( UT_DCT_SEPA);

	SettlingTimeHandle	settling_time	= UTL_GetSettlingTimeHandle();
	UTL_SetSettlingTime        ( settling_time, 1.000 mS);
	UTL_SetSettlingTimeAfterRon( settling_time, 1.000 mS);
	UTL_SetSettlingTimeAfterRof( settling_time, 1.000 mS);
	UTL_SendSettlingTime       ( settling_time);
	UTL_DeleteHandle           ( settling_time);

	PowerSeqHandle	power_seq	= UTL_GetPowerSeqHandle();
	UTL_AddPowerSeqUnit    ( power_seq, 1, UT_UNIT_VSALL );
	UTL_SetPowerSeqWaitTime( power_seq, 1, 50.00 mS      );
	UTL_AddPowerSeqUnit    ( power_seq, 2, UT_UNIT_VIALL );
	UTL_AddPowerSeqUnit    ( power_seq, 2, UT_UNIT_VTALL );
	UTL_SetPowerSeqWaitTime( power_seq, 2, 50.00 mS      );
	UTL_AddPowerSeqUnit    ( power_seq, 3, UT_UNIT_OTHERS);
	UTL_SetPowerSeqWaitTime( power_seq, 3, 50.00 mS      );
	UTL_SendPowerSeq       ( power_seq);
	UTL_DeleteHandle       ( power_seq);

	IlModeHandle    handle = UTL_GetIlModeHandle();
	UTL_SetIlMode          ( handle,  4);
//	UTL_SetIlComparisonMode( handle,  1);        // for T5503HS2 9G PEM
	UTL_SendIlMode         ( handle    );
	UTL_DeleteHandle       ( handle    );

	DefinePinlist();
}

void	TestMain( Test_t *test_flow, int test_count) {
	for ( int i = 0; i<test_count; i++)
		test_flow[ i].type ( &test_flow[ i]);
}

inline	static	void	ShowTime(void) {
	CheckButton	overflow;
	static	double	prev	= 0.0;
	double		curr	= UTL_ReadTimer(&overflow);
	printf(":%6.3f[s]: %6.3f[s]\n", ((overflow)?(NAN):(curr)), ((overflow)?(NAN):(curr-prev))); prev = curr;
}

void	TestEnd  (void) {
	DutCursor dut_cursor;
	UT_DUT    dut;
	printf("------------------------------------------------------------------------------------------------\n");
	printf("    : %-67s:","Total Bin");
	dut_cursor = UTL_GetDutCursor( UT_MDUT);
	while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) {
		if      ( (UTL_ReadCategory( dut,   2) == UT_ON) )    { UTL_SendSort( dut, 7); UTL_SetFinalResultOnly   ( dut, UT_RES_DC  ); }
		else if ( (UTL_ReadCategory( dut,   4) == UT_ON) ||
			  (UTL_ReadCategory( dut,   6) == UT_ON) ||
			  (UTL_ReadCategory( dut,   8) == UT_ON) )    { UTL_SendSort( dut, 6); UTL_SetFinalResultOnly   ( dut, UT_RES_DC  ); }
		else if ( (UTL_ReadCategory( dut,  10) == UT_ON) )    { UTL_SendSort( dut, 5); UTL_SetFinalResultOnly   ( dut, UT_RES_DC  ); }
		else if ( (UTL_ReadCategory( dut, 130) == UT_ON) &&
			  (UTL_ReadCategory( dut, 150) == UT_ON) )    { UTL_SendSort( dut, 1); UTL_ResetFinalResultOnly ( dut, UT_RES_FUNC); }
		else if ( (UTL_ReadCategory( dut, 120) == UT_ON) &&
			  (UTL_ReadCategory( dut, 140) == UT_ON) )    { UTL_SendSort( dut, 2); UTL_ResetFinalResultOnly ( dut, UT_RES_FUNC); }
		else if	( (UTL_ReadCategory( dut, 110) == UT_ON) )    { UTL_SendSort( dut, 3); UTL_ResetFinalResultOnly ( dut, UT_RES_FUNC); }
		else if	( (UTL_ReadCategory( dut, 100) == UT_ON) )    { UTL_SendSort( dut, 4); UTL_ResetFinalResultOnly ( dut, UT_RES_FUNC); }
		else                                                  { UTL_SendSort( dut, 8); UTL_SetFinalResultOnly   ( dut, UT_RES_ALL ); }
	}
	UTL_DeleteCursor( dut_cursor);
	dut_cursor = UTL_GetDutCursor( UT_MDUT);
	while( (dut = UTL_NextDut( dut_cursor)) != UT_NOMORE) printf("%d%s",UTL_ReadSort( dut),((dut%8)==0?" ":"") );
	UTL_DeleteCursor( dut_cursor); 
	ShowTime();
}

