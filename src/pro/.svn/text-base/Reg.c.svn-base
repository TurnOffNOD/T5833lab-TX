#include <test.h>
#include <math.h>
#include "Def.h"
#include "Reg.h"
#include "reg.h"
#include "string.h"

void	RegFunc( Test_t *test) {

	uint16_t	MR01 = 0x00;	// BL, WR-PRE RD-PRE nWR for AP, RPST 
	uint16_t	MR02 = 0x00;	// RL, WL, WLS, rite Leveling 
	uint16_t	MR03 = 0x00;	// PU_CAL, WR-PST, PPRP, PDDS, DBI-RD, DBI-WR 
	uint16_t	MR04 = 0x00;	// Refresh rate,  
	uint16_t	MR11 = 0x00;	// DQ-ODT, CA-ODT,  
	uint16_t	MR12 = 0x40;	// VrefCA, VrefCA Range 
	uint16_t	MR14 = 0x40;	// VrefDQ, VrefDQ Range 
	uint16_t	MR22 = 0x00;	// SOC-ODT, 


	int		RLset = 0; // X16,RDBI Disable=0; X16 DBI Enable=1; X8. RDBI Disable=2; X8 RDBI Enable=3;
	int		WLS   = 0;

	if      ( (test->RDBI == false)  && (IO_WIDTH == 16) ) RLset    = 0;
	else if ( (test->RDBI == true )  && (IO_WIDTH == 16) ) RLset    = 1;
	else if ( (test->RDBI == false)  && (IO_WIDTH ==  8) ) RLset    = 2;
	else if ( (test->RDBI == true )  && (IO_WIDTH ==  8) ) RLset    = 3;

	if	( (IO_WIDTH ==16) && (test->WL <= 18) ) WLS= 0;
	else if	( (IO_WIDTH ==16) && (test->WL >  18) ) WLS= 1;
	else if	( (IO_WIDTH == 8) && (test->WL <= 18) ) WLS= 2;
	else if	( (IO_WIDTH == 8) && (test->WL >  18) ) WLS=3;


	if	( test->BL == 16                  ) MR01 |= 0x02;
	else if	( test->BL == 32                  ) MR01 |= 0x01;
	if	( fabs(test->WR_PRE - 2.0 ) < 0.1 ) MR01 |= 0x04;
	if	( strcmp(test->RD_PRE, "Toggle") ==0     ) MR01 |= 0x08;
	if	( fabs(test->RD_PST - 1.5 ) < 0.1 ) MR01 |= 0x80;
	if	( test->WR == 10) MR01 |= 0x10;
	else if ( test->WR == 16) MR01 |= 0x20;
	else if ( test->WR == 20) MR01 |= 0x30;
	else if ( test->WR == 24) MR01 |= 0x40;
	else if ( test->WR == 30) MR01 |= 0x50;
	else if ( test->WR == 34) MR01 |= 0x60;
	else if ( test->WR == 40) MR01 |= 0x70;


	if	( RLset == 0 ){ // Read DBI disable x16 mode
		MR03 |= 0x00; 
		if	( (test->RL == 6)  && (test->RTP == 8)  ) MR02 |= 0x00;
		else if	( (test->RL ==10)  && (test->RTP == 8)  ) MR02 |= 0x01;
		else if	( (test->RL ==14)  && (test->RTP == 8)  ) MR02 |= 0x02;
		else if	( (test->RL ==20)  && (test->RTP == 8)  ) MR02 |= 0x03;
		else if	( (test->RL ==24)  && (test->RTP ==10)  ) MR02 |= 0x04;
		else if	( (test->RL ==28)  && (test->RTP ==12)  ) MR02 |= 0x05;
		else if	( (test->RL ==32)  && (test->RTP ==14)  ) MR02 |= 0x06;
		else if	( (test->RL ==36)  && (test->RTP ==16)  ) MR02 |= 0x07;
	}
	else if	( RLset == 1){ // read DBI enable x16 mode
		MR03 |= 0x40; 
		if	( (test->RL == 6)  && (test->RTP == 8)  ) MR02 |= 0x00;
		else if	( (test->RL ==12)  && (test->RTP == 8)  ) MR02 |= 0x01;
		else if	( (test->RL ==16)  && (test->RTP == 8)  ) MR02 |= 0x02;
		else if	( (test->RL ==22)  && (test->RTP == 8)  ) MR02 |= 0x03;
		else if	( (test->RL ==28)  && (test->RTP ==10)  ) MR02 |= 0x04;
		else if	( (test->RL ==32)  && (test->RTP ==12)  ) MR02 |= 0x05;
		else if	( (test->RL ==36)  && (test->RTP ==14)  ) MR02 |= 0x06;
		else if	( (test->RL ==40)  && (test->RTP ==16)  ) MR02 |= 0x07;
	}
	else if	( RLset == 2){ // read DBI disable x8 mode
		MR03 |= 0x00; 
		if	( (test->RL == 6)  && (test->RTP == 8)  ) MR02 |= 0x00;
		else if	( (test->RL ==12)  && (test->RTP == 8)  ) MR02 |= 0x01;
		else if	( (test->RL ==16)  && (test->RTP == 8)  ) MR02 |= 0x02;
		else if	( (test->RL ==22)  && (test->RTP == 8)  ) MR02 |= 0x03;
		else if	( (test->RL ==26)  && (test->RTP ==10)  ) MR02 |= 0x04;
		else if	( (test->RL ==32)  && (test->RTP ==12)  ) MR02 |= 0x05;
		else if	( (test->RL ==36)  && (test->RTP ==14)  ) MR02 |= 0x06;
		else if	( (test->RL ==40)  && (test->RTP ==16)  ) MR02 |= 0x07;
	}

	else if	( RLset == 3){ // read DBI enable x8 mode
		MR03 |= 0x40; 
		if	( (test->RL == 6)  && (test->RTP == 8)  ) MR02 |= 0x00;
		else if	( (test->RL ==12)  && (test->RTP == 8)  ) MR02 |= 0x01;
		else if	( (test->RL ==18)  && (test->RTP == 8)  ) MR02 |= 0x02;
		else if	( (test->RL ==24)  && (test->RTP == 8)  ) MR02 |= 0x03;
		else if	( (test->RL ==30)  && (test->RTP ==10)  ) MR02 |= 0x04;
		else if	( (test->RL ==36)  && (test->RTP ==12)  ) MR02 |= 0x05;
		else if	( (test->RL ==40)  && (test->RTP ==14)  ) MR02 |= 0x06;
		else if	( (test->RL ==44)  && (test->RTP ==16)  ) MR02 |= 0x07;
	}

	if	( WLS == 0){ // X16 mode, MR2 OP[6]=0B set A
		if	( test->WL == 4) MR02 |= 0x00;
		else if	( test->WL == 6) MR02 |= 0x08;
		else if	( test->WL == 8) MR02 |= 0x10;
		else if	( test->WL ==10) MR02 |= 0x18;
		else if	( test->WL ==12) MR02 |= 0x20;
		else if	( test->WL ==14) MR02 |= 0x28;
		else if	( test->WL ==16) MR02 |= 0x30;
		else if	( test->WL ==18) MR02 |= 0x38;
	}
	else if	( WLS == 1){ // X16 mode, MR2 OP[6]=1B set B
		if	( test->WL == 4) MR02 |= 0x40;
		else if	( test->WL == 8) MR02 |= 0x48;
		else if	( test->WL ==12) MR02 |= 0x50;
		else if	( test->WL ==18) MR02 |= 0x58;
		else if	( test->WL ==22) MR02 |= 0x60;
		else if	( test->WL ==26) MR02 |= 0x68;
		else if	( test->WL ==30) MR02 |= 0x70;
		else if	( test->WL ==34) MR02 |= 0x78;
	}
	else if	( WLS == 2){ // X8  mode, MR2 OP[6]=0B set A
		if	( test->WL == 4) MR02 |= 0x00;
		else if	( test->WL == 6) MR02 |= 0x08;
		else if	( test->WL == 8) MR02 |= 0x10;
		else if	( test->WL ==10) MR02 |= 0x18;
		else if	( test->WL ==12) MR02 |= 0x20;
		else if	( test->WL ==14) MR02 |= 0x28;
		else if	( test->WL ==16) MR02 |= 0x30;
		else if	( test->WL ==18) MR02 |= 0x38;
	}
	else if	( WLS == 3){ // X8  mode, MR2 OP[6]=1B set B
		if	( test->WL == 4) MR02 |= 0x40;
		else if	( test->WL == 8) MR02 |= 0x48;
		else if	( test->WL ==12) MR02 |= 0x50;
		else if	( test->WL ==18) MR02 |= 0x58;
		else if	( test->WL ==22) MR02 |= 0x60;
		else if	( test->WL ==26) MR02 |= 0x68;
		else if	( test->WL ==30) MR02 |= 0x70;
		else if	( test->WL ==34) MR02 |= 0x78;
	}

	if	( fabs(test->PU_CAL - 3.0) < 0.1 ) MR03 |= 0x01;
	else if	( fabs(test->PU_CAL - 2.5) < 0.1 ) MR03 |= 0x00;
	if	( fabs(test->WR_PST - 1.5) < 0.1 ) MR03 |= 0x02;
	else if	( fabs(test->WR_PST - 0.5) < 0.1 ) MR03 |= 0x00;


	if      ( fabs(test->PDDS-RZQ/1)<0.1 ) MR03 |= 0x08;
	else if ( fabs(test->PDDS-RZQ/2)<0.1 ) MR03 |= 0x10;
	else if ( fabs(test->PDDS-RZQ/3)<0.1 ) MR03 |= 0x18;
	else if ( fabs(test->PDDS-RZQ/4)<0.1 ) MR03 |= 0x20;
	else if ( fabs(test->PDDS-RZQ/5)<0.1 ) MR03 |= 0x28;
	else if ( fabs(test->PDDS-RZQ/6)<0.1 ) MR03 |= 0x30;
	if      ( test->WDBI == true         ) MR03 |= 0x80;


	if	( fabs(test->REF_RATE - 4.00)< 0.1 ) MR04 |= 0x01;
	else if	( fabs(test->REF_RATE - 2.00)< 0.1 ) MR04 |= 0x02;
	else if	( fabs(test->REF_RATE - 1.00)< 0.1 ) MR04 |= 0x03;
	else if	( fabs(test->REF_RATE - 0.50)< 0.1 ) MR04 |= 0x04;
	else if	( fabs(test->REF_RATE - 0.25)< 0.1 ) MR04 |= 0x05;
	else if	( fabs(test->REF_RATE - 6.00)< 0.1 ) MR04 |= 0x06;
	else if	( fabs(test->REF_RATE - 7.00)< 0.1 ) MR04 |= 0x07;
	else                                         MR04 |= 0x00;


	if      ( fabs(test->ODT_DQ  - HI_Z ) < 0.1 ) MR11 |= 0x00;
	else if ( fabs(test->ODT_DQ  - RZQ/1) < 0.1 ) MR11 |= 0x01;
	else if ( fabs(test->ODT_DQ  - RZQ/2) < 0.1 ) MR11 |= 0x02;
	else if ( fabs(test->ODT_DQ  - RZQ/3) < 0.1 ) MR11 |= 0x03;
	else if ( fabs(test->ODT_DQ  - RZQ/4) < 0.1 ) MR11 |= 0x04;
	else if ( fabs(test->ODT_DQ  - RZQ/5) < 0.1 ) MR11 |= 0x05;
	else if ( fabs(test->ODT_DQ  - RZQ/6) < 0.1 ) MR11 |= 0x06;

	if      ( fabs(test->ODT_CA  - HI_Z ) < 0.1 ) MR11 |= 0x00;
	else if ( fabs(test->ODT_CA  - RZQ/1) < 0.1 ) MR11 |= 0x10;
	else if ( fabs(test->ODT_CA  - RZQ/2) < 0.1 ) MR11 |= 0x20;
	else if ( fabs(test->ODT_CA  - RZQ/3) < 0.1 ) MR11 |= 0x30;
	else if ( fabs(test->ODT_CA  - RZQ/4) < 0.1 ) MR11 |= 0x40;
	else if ( fabs(test->ODT_CA  - RZQ/5) < 0.1 ) MR11 |= 0x50;
	else if ( fabs(test->ODT_CA  - RZQ/6) < 0.1 ) MR11 |= 0x60;

	if      ( fabs(test->ODT_SOC - HI_Z ) < 0.1 ) MR22 |= 0x00;
	else if ( fabs(test->ODT_SOC - RZQ/1) < 0.1 ) MR22 |= 0x01;
	else if ( fabs(test->ODT_SOC - RZQ/2) < 0.1 ) MR22 |= 0x02;
	else if ( fabs(test->ODT_SOC - RZQ/3) < 0.1 ) MR22 |= 0x03;
	else if ( fabs(test->ODT_SOC - RZQ/4) < 0.1 ) MR22 |= 0x04;
	else if ( fabs(test->ODT_SOC - RZQ/5) < 0.1 ) MR22 |= 0x05;
	else if ( fabs(test->ODT_SOC - RZQ/6) < 0.1 ) MR22 |= 0x06;



//	if	(      test->VREF_CA < 30.00        ) { MR12 = ((uint16_t)((test->VREF_CA-10.0) / 0.4)); MR12 |= 0x00; }
//	else                                          { MR12 = ((uint16_t)((test->VREF_CA-22.0) / 0.4)); MR12 |= 0x40; }
//	if	(      test->VREF_DQ < 30.00        ) { MR14 = ((uint16_t)((test->VREF_DQ-10.0) / 0.4)); MR14 |= 0x00; }
//	else                                          { MR14 = ((uint16_t)((test->VREF_DQ-22.0) / 0.4)); MR14 |= 0x40; }
	if	(      test->VREF_CA < 30.00        ) { MR12 = ((uint16_t)((test->VREF_CA-10.0)*10 / 4)); MR12 |= 0x00; }
	else                                          { MR12 = ((uint16_t)((test->VREF_CA-22.0)*10 / 4)); MR12 |= 0x40; }
	if	(      test->VREF_DQ < 30.00        ) { MR14 = ((uint16_t)((test->VREF_DQ-10.0)*10 / 4)); MR14 |= 0x00; }
	else                                          { MR14 = ((uint16_t)((test->VREF_DQ-22.0)*10 / 4)); MR14 |= 0x40; }


        RegHandle       handle = UTL_GetRegHandle();
	D1A   ( MR01        ); //printf ("MR01=%x\n",MR01);
	D1B   ( MR02        ); //printf ("MR02=%x\n",MR02);
	D1C   ( MR03        ); //printf ("MR03=%x\n",MR03);
	D1D   ( MR04        ); //printf ("MR04=%x\n",MR04);
	D1E   ( MR11        ); //printf ("MR11=%x\n",MR11);
	D1F   ( MR12        ); //printf ("MR12=%x\n",MR12);
	D1G   ( MR14        ); //printf ("MR14=%x\n",MR14);
	D1H   ( MR22        ); //printf ("MR22=%x\n",MR22);

	BH    ( 0           );	NH    ( 0           );	BH_2  ( 0           );	NH_2  ( 0           );
	BD1   ( 1           );	ND1   ( 1           );	BD1_2 ( 1           );	ND1_2 ( 1           );
	BD2   ( 2           );	ND2   ( 2           );	BD2_2 ( 2           );	ND2_2 ( 2           );
	BD3   ( 3           );	ND3   ( 3           );	BD3_2 ( 3           );	ND3_2 ( 3           );
	BD4   ( 4           );	ND4   ( 4           );	BD4_2 ( 4           );	ND4_2 ( 4           );
	BD5   ( 5           );	ND5   ( 5           );	BD5_2 ( 5           );	ND5_2 ( 5           );
	BD6   ( 6           );	ND6   ( 6           );	BD6_2 ( 6           );	ND6_2 ( 6           );
	BD7   ( 7           );	ND7   ( 7           );	BD7_2 ( 7           );	ND7_2 ( 7           );
	
	
	XMAX  ( 0x3fff      );
	YMAX  ( 0x3ff       );


	TPH1_1( test->data1 );
	TPH2_1( test->data2 );
	TPH1_2( test->data1 );
	TPH2_2( test->data2 );

	IDX1  ( 6           );
	IDX2  ( 0x3ffd      );
	IDX3  ( 0x001e      );
	IDX4  ( 0x3ffe      );
	IDX5  ( 0x001e      );
	IDX6  ( 0x000d      );
	IDX7  ( (uint32_t)((280 nS / test->tCK) /4) );
	IDX8  ( 0x003e      );
	REFRESH( 3.904 uS    );
        UTL_SendReg( handle);
        UTL_DeleteHandle( handle);
}
