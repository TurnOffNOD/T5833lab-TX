void	PinOpen( Test_t *test) {
        static Pin_t    *pin_group = NULL;
	if ( pin_group == NULL ) {
		pin_group		= (Pin_t *)malloc( sizeof(Pin_t));
		pin_group->CK_t  	= pin( CK_t  , OPEN);
		pin_group->CK_c  	= pin( CK_c  , OPEN);
		pin_group->CA0   	= pin( CA0   , OPEN);
		pin_group->CA1   	= pin( CA1   , OPEN);
		pin_group->CA2   	= pin( CA2   , OPEN);
		pin_group->CA3   	= pin( CA3   , OPEN);
		pin_group->CA4   	= pin( CA4   , OPEN);
		pin_group->CA5   	= pin( CA5   , OPEN);
		pin_group->CS    	= pin( CS    , OPEN);
		pin_group->CKE   	= pin( CKE   , OPEN);
		pin_group->RST_n 	= pin( RST_n , OPEN);
		pin_group->ODTCA 	= pin( ODTCA , OPEN);
		pin_group->DQ0   	= pin( DQ0   , OPEN);
		pin_group->DQ1   	= pin( DQ1   , OPEN);
		pin_group->DQ2   	= pin( DQ2   , OPEN);
		pin_group->DQ3   	= pin( DQ3   , OPEN);
		pin_group->DQ4   	= pin( DQ4   , OPEN);
		pin_group->DQ5   	= pin( DQ5   , OPEN);
		pin_group->DQ6   	= pin( DQ6   , OPEN);
		pin_group->DQ7   	= pin( DQ7   , OPEN);
		pin_group->DMI   	= pin( DMI   , OPEN);
		pin_group->DQS_t	= pin( DQS_t , OPEN);
		pin_group->DQS_c	= pin( DQS_c , OPEN);
	}
//	pin_group->WL  = test->WL;
//	pin_group->RL  = test->RL; 
	PinSend( pin_group);
}

