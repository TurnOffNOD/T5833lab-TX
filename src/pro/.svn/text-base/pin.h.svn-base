typedef	struct	Pin {
	int	WL     ;
	int	RL     ;
	pin_t	*CK_t  ;
	pin_t	*CK_c  ;
	pin_t	*CA0   ;
	pin_t	*CA1   ;
	pin_t	*CA2   ;
	pin_t	*CA3   ;
	pin_t	*CA4   ;
	pin_t	*CA5   ;
//	pin_t	*CS0   ;
//	pin_t	*CS1   ;
//	pin_t	*CS2   ;
	pin_t	*CS    ;
//	pin_t	*CKE0  ;
//	pin_t	*CKE1  ;
//	pin_t	*CKE2  ;
	pin_t	*CKE   ;
	pin_t	*RST_n ;
	pin_t	*ODTCA ;
	pin_t	*DQ0   ;
	pin_t	*DQ1   ;
	pin_t	*DQ2   ;
	pin_t	*DQ3   ;
	pin_t	*DQ4   ;
	pin_t	*DQ5   ;
	pin_t	*DQ6   ;
	pin_t	*DQ7   ;
	pin_t	*DMI   ;
	pin_t	*DQS_t ;
	pin_t	*DQS_c ;
} Pin_t;
#define pinlist(a,...)   (UTL_CreatePinList((char *)a), UTL_SetPinType((char *)a,UT_PINTYPE_PIN),pinlist_(a,__VA_ARGS__,NULL))
void	pinlist_( const char *name, ...) {
        UTL_CreatePinList( (char *)name);
        UTL_SetPinType   ( (char *)name, UT_PINTYPE_PIN);

        va_list     va;
        const char *list;
        va_start(va, name);
        while( (list = va_arg(va, const char *)) != NULL )
                UTL_AppendPinList((char *)name, (char *)list);
        va_end(va);
}
inline void     vsset ( char *name, int pin_number) {
        UTL_CreatePinList( name); UTL_SetPinType   ( name, UT_PINTYPE_VS  ); UTL_AddPinNumber ( name, pin_number     );
}
inline void     pinset( char *name, int pin_number) {
        UTL_CreatePinList( name); UTL_SetPinType   ( name, UT_PINTYPE_PIN ); UTL_AddPinNumber ( name, pin_number     );
}
inline void	pinSend( pin_t *pin) { UTL_SendPin( pin->handle, (char *)pin->name); }
inline void     PinSend( Pin_t *pin_group) {
	UTL_SendPin( pin_group->RST_n ->handle, RST_n    );
	UTL_SendPin( pin_group->CK_t  ->handle, CK_t_A   ); UTL_SendPin( pin_group->CK_t  ->handle, CK_t_B   );
	UTL_SendPin( pin_group->CK_c  ->handle, CK_c_A   ); UTL_SendPin( pin_group->CK_c  ->handle, CK_c_B   );
//	UTL_SendPin( pin_group->CS0   ->handle, CS0_A    ); UTL_SendPin( pin_group->CS0   ->handle, CS0_B    );
//	UTL_SendPin( pin_group->CS1   ->handle, CS1_A    ); UTL_SendPin( pin_group->CS1   ->handle, CS1_B    );
//	UTL_SendPin( pin_group->CS2   ->handle, CS2_A    ); UTL_SendPin( pin_group->CS2   ->handle, CS2_B    );
	UTL_SendPin( pin_group->CS    ->handle, CS0_A    ); UTL_SendPin( pin_group->CS    ->handle, CS0_B    );
//	UTL_SendPin( pin_group->CKE0  ->handle, CKE0_A   ); UTL_SendPin( pin_group->CKE0  ->handle, CKE0_B   );
//	UTL_SendPin( pin_group->CKE1  ->handle, CKE1_A   ); UTL_SendPin( pin_group->CKE1  ->handle, CKE1_B   );
//	UTL_SendPin( pin_group->CKE2  ->handle, CKE2_A   ); UTL_SendPin( pin_group->CKE2  ->handle, CKE2_B   );
	UTL_SendPin( pin_group->CKE   ->handle, CKE0_A   ); UTL_SendPin( pin_group->CKE   ->handle, CKE0_B   );
	UTL_SendPin( pin_group->CA0   ->handle, CA0_A    ); UTL_SendPin( pin_group->CA0   ->handle, CA0_B    );
	UTL_SendPin( pin_group->CA1   ->handle, CA1_A    ); UTL_SendPin( pin_group->CA1   ->handle, CA1_B    );
	UTL_SendPin( pin_group->CA2   ->handle, CA2_A    ); UTL_SendPin( pin_group->CA2   ->handle, CA2_B    );
	UTL_SendPin( pin_group->CA3   ->handle, CA3_A    ); UTL_SendPin( pin_group->CA3   ->handle, CA3_B    );
	UTL_SendPin( pin_group->CA4   ->handle, CA4_A    ); UTL_SendPin( pin_group->CA4   ->handle, CA4_B    );
	UTL_SendPin( pin_group->CA5   ->handle, CA5_A    ); UTL_SendPin( pin_group->CA5   ->handle, CA5_B    );
	UTL_SendPin( pin_group->ODTCA ->handle, ODTCA_A  ); UTL_SendPin( pin_group->ODTCA ->handle, ODTCA_B  );
	UTL_SendPin( pin_group->DQS_t ->handle, DQS0_t_A ); UTL_SendPin( pin_group->DQS_t ->handle, DQS0_t_B );
	UTL_SendPin( pin_group->DQS_c ->handle, DQS0_c_A ); UTL_SendPin( pin_group->DQS_c ->handle, DQS0_c_B );
	UTL_SendPin( pin_group->DQ0   ->handle, DQ0_A    ); UTL_SendPin( pin_group->DQ0   ->handle, DQ0_B    );
	UTL_SendPin( pin_group->DQ1   ->handle, DQ1_A    ); UTL_SendPin( pin_group->DQ1   ->handle, DQ1_B    );
	UTL_SendPin( pin_group->DQ2   ->handle, DQ2_A    ); UTL_SendPin( pin_group->DQ2   ->handle, DQ2_B    );
	UTL_SendPin( pin_group->DQ3   ->handle, DQ3_A    ); UTL_SendPin( pin_group->DQ3   ->handle, DQ3_B    );
	UTL_SendPin( pin_group->DQ4   ->handle, DQ4_A    ); UTL_SendPin( pin_group->DQ4   ->handle, DQ4_B    );
	UTL_SendPin( pin_group->DQ5   ->handle, DQ5_A    ); UTL_SendPin( pin_group->DQ5   ->handle, DQ5_B    );
	UTL_SendPin( pin_group->DQ6   ->handle, DQ6_A    ); UTL_SendPin( pin_group->DQ6   ->handle, DQ6_B    );
	UTL_SendPin( pin_group->DQ7   ->handle, DQ7_A    ); UTL_SendPin( pin_group->DQ7   ->handle, DQ7_B    );
	UTL_SendPin( pin_group->DMI   ->handle, DMI0_A   ); UTL_SendPin( pin_group->DMI   ->handle, DMI0_B   );
	UTL_SendPin( pin_group->DQS_t ->handle, DQS1_t_A ); UTL_SendPin( pin_group->DQS_t ->handle, DQS1_t_B );
	UTL_SendPin( pin_group->DQS_c ->handle, DQS1_c_A ); UTL_SendPin( pin_group->DQS_c ->handle, DQS1_c_B );
	UTL_SendPin( pin_group->DQ0   ->handle, DQ8_A    ); UTL_SendPin( pin_group->DQ0   ->handle, DQ8_B    );
	UTL_SendPin( pin_group->DQ1   ->handle, DQ9_A    ); UTL_SendPin( pin_group->DQ1   ->handle, DQ9_B    );
	UTL_SendPin( pin_group->DQ2   ->handle, DQ10_A   ); UTL_SendPin( pin_group->DQ2   ->handle, DQ10_B   );
	UTL_SendPin( pin_group->DQ3   ->handle, DQ11_A   ); UTL_SendPin( pin_group->DQ3   ->handle, DQ11_B   );
	UTL_SendPin( pin_group->DQ4   ->handle, DQ12_A   ); UTL_SendPin( pin_group->DQ4   ->handle, DQ12_B   );
	UTL_SendPin( pin_group->DQ5   ->handle, DQ13_A   ); UTL_SendPin( pin_group->DQ5   ->handle, DQ13_B   );
	UTL_SendPin( pin_group->DQ6   ->handle, DQ14_A   ); UTL_SendPin( pin_group->DQ6   ->handle, DQ14_B   );
	UTL_SendPin( pin_group->DQ7   ->handle, DQ15_A   ); UTL_SendPin( pin_group->DQ7   ->handle, DQ15_B   );
	UTL_SendPin( pin_group->DMI   ->handle, DMI1_A   ); UTL_SendPin( pin_group->DMI   ->handle, DMI1_B   );
};


