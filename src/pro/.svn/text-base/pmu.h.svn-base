// for T5833
#define	R80uA			(UTL_SetDcSrange( handle, 20.00 uA, -20.00 uA))
#define	R800uA			(UTL_SetDcSrange( handle, 200.0 uA, -200.0 uA))
#define	R8mA			(UTL_SetDcSrange( handle, 2.000 mA, -2.000 mA))
#define	R80mA			(UTL_SetDcSrange( handle, 48.00 mA, -48.00 mA))
#define	M20V			(UTL_SetDcMrange( handle, 7.000  V, -0.300  V))
#define	Mi20V			(UTL_SetDcMrange( handle, 0.300  V, -7.000  V))
#define	R20V			(UTL_SetDcSrange( handle, 7.000  V, -7.000  V))
#define	M8uA			(UTL_SetDcMrange( handle, 5.000 uA, -5.000 uA))
#define	M80uA			(UTL_SetDcMrange( handle, 20.00 uA, -20.00 uA))
#define	M800uA			(UTL_SetDcMrange( handle, 200.0 uA, -200.0 uA))
#define	M8mA			(UTL_SetDcMrange( handle, 2.000 mA, -2.000 mA))
#define	M128mA			(UTL_SetDcMrange( handle, 48.00 mA, -48.00 mA))

#define Clamp(p,m)              (UTL_SetDcPclamp( handle, p   ),             \
                                 UTL_SetDcMclamp( handle, m   )               )
