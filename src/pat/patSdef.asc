RDX  10
; -------- To control Each Pin --------
	SDEF DQSW   = C20
	SDEF DQSR   = C21
	SDEF DQSLL  =
	SDEF DQSHL  = C22
	SDEF CS0    = C10
	SDEF CS1    = C11
	SDEF CS2    = C12
	SDEF CA0    = C4
	SDEF CA1    = C5
	SDEF CA2    = C6
	SDEF CA3    = C7
	SDEF CA4    = C8
	SDEF CA5    = C9
	SDEF CKE0L  = C14
	SDEF CKE1L  = C15
	SDEF CKE2L  = C16
	SDEF CKEL   = CKE0L CKE1L CKE2L
	SDEF CKSTP  = C29		; Clock Stop
	SDEF ODTCA  = C3
	SDEF RESET  = C13
	SDEF UBMEN  = C25
	SDEF UBMAP0 = C26
	SDEF UBMAP1 = C27
	SDEF UBMAP2 = C28
; -------- For Command Input --------
	;             CA0,CA1,CA2,CA3,CA4,CA5,AP ,        ;
	SDEF ACT11  = CA0,   ,   ,   ,   ,   ,   ,;;XASV    ; Activate-1
	SDEF ACT12  =    ,   ,   ,   ,   ,   ,   ,;;        ; Activate-1
	SDEF ACT21  = CA0,CA1,   ,   ,   ,   ,   ,;;        ; Activate-2
	SDEF ACT22  =    ,   ,   ,   ,   ,   ,   ,;;        ; Activate-2
	SDEF WR_S1  =    ,   ,CA2,   ,   ,   ,   ,;;XALD(8) ; Write(BL16)
	SDEF WR_S2  =    ,   ,   ,   ,   ,   ,   ,;;        ; Write(BL16)
	SDEF WR_L1  =    ,   ,CA2,   ,   ,CA5,   ,;;XALD(16); Write(BL32)
	SDEF WR_L2  =    ,   ,   ,   ,   ,   ,   ,;;        ; Write(BL32)
	SDEF WRAS1  =    ,   ,CA2,   ,   ,   ,   ,;;XALD(8) ; Write(BL16) + Auto Precharge
	SDEF WRAS2  =    ,   ,   ,   ,   ,CA5,   ,;;        ; Write(BL16) + Auto Precharge
	SDEF WRAL1  =    ,   ,CA2,   ,   ,CA5,   ,;;XALD(16); Write(BL32) + Auto Precharge
	SDEF WRAL2  =    ,   ,   ,   ,   ,CA5,   ,;;        ; Write(BL32) + Auto Precharge
	SDEF MWR_1  =    ,   ,CA2,CA3,   ,   ,   ,;;XALD(8) ; MaskWrite                 (Masked Write support BL16 only)
	SDEF MWR_2  =    ,   ,   ,   ,   ,   ,   ,;;        ; MaskWrite                 (Masked Write support BL16 only)
	SDEF MWRA1  =    ,   ,CA2,CA3,   ,   ,   ,;;XALD(8) ; MaskWrite + Auto Precharge(Masked Write support BL16 only)
	SDEF MWRA2  =    ,   ,   ,   ,   ,CA5,   ,;;        ; MaskWrite + Auto Precharge(Masked Write support BL16 only)
	SDEF RD_S1  =    ,CA1,   ,   ,   ,   ,   ,;;XALD(8) ; Read(BL16)
	SDEF RD_S2  =    ,   ,   ,   ,   ,   ,   ,;;        ; Read(BL16)
	SDEF RD_L1  =    ,CA1,   ,   ,   ,CA5,   ,;;XALD(16); Read(BL32)
	SDEF RD_L2  =    ,   ,   ,   ,   ,   ,   ,;;        ; Read(BL32)
	SDEF RDAS1  =    ,CA1,   ,   ,   ,   ,   ,;;XALD(8) ; Read(BL16) + Auto Precharge
	SDEF RDAS2  =    ,   ,   ,   ,   ,CA5,   ,;;        ; Read(BL16) + Auto Precharge
	SDEF RDAL1  =    ,CA1,   ,   ,   ,CA5,   ,;;XALD(16); Read(BL32) + Auto Precharge
	SDEF RDAL2  =    ,   ,   ,   ,   ,CA5,   ,        ; Read(BL32) + Auto Precharge
	SDEF PRE_1  =    ,   ,   ,   ,CA4,   ,   ,        ; Precharge(Per Bank)
	SDEF PRE_2  =    ,   ,   ,   ,   ,   ,   ,        ; Precharge(Per Bank)
	SDEF PREA1  =    ,   ,   ,   ,CA4,CA5,   ,        ; Precharge(All Bank)
	SDEF PREA2  =    ,   ,   ,   ,   ,   ,   ,        ; Precharge(All Bank)
	SDEF REF1   =    ,   ,   ,CA3,   ,   ,   ,        ; Refresh(Per Bank)
	SDEF REF2   =    ,   ,   ,   ,   ,   ,   ,        ; Refresh(Per Bank)
	SDEF REFA1  =    ,   ,   ,CA3,   ,CA5,   ,        ; Refresh(All Bank)
	SDEF REFA2  =    ,   ,   ,   ,   ,   ,   ,        ; Refresh(All Bank)
	SDEF CAS21  =    ,CA1,   ,   ,CA4,   ,   ,        ; CAS2                  jinl
	SDEF CAS22  =    ,   ,   ,   ,   ,   ,   ,        ; CAS2
	SDEF MRW11  =    ,CA1,CA2,   ,   ,   ,   ,        ; Mode Register Write1
	SDEF MRW12  =    ,   ,   ,   ,   ,   ,   ,        ; Mode Register Write1
	SDEF MRW21  =    ,CA1,CA2,   ,CA4,   ,   ,        ; Mode Register Write2
	SDEF MRW22  =    ,   ,   ,   ,   ,   ,   ,        ; Mode Register Write2
	SDEF MRR11  =    ,CA1,CA2,CA3,   ,   ,   ,        ; Mode Register Read
	SDEF MRR12  =    ,   ,   ,   ,   ,   ,   ,        ; Mode Register Read
	SDEF SRE1   =    ,   ,   ,CA3,CA4,   ,   ,        ; Self Refresh Entry
	SDEF SRE2   =    ,   ,   ,   ,   ,   ,   ,        ; Self Refresh Entry
	SDEF SRX1   =    ,   ,CA2,   ,CA4,   ,   ,        ; Self Refresh Exit
	SDEF SRX2   =    ,   ,   ,   ,   ,   ,   ,        ; Self Refresh Exit
	SDEF DES    =    ,   ,   ,   ,   ,   ,   ,        ;
	SDEF ZQCAL1 =    ,   ,   ,   ,   ,CA5,   ,        ; ZQCal Start
	SDEF ZQCAL2 = CA0,CA1,CA2,CA3,   ,   ,   ,        ; ZQCal Start
	SDEF ZQLAT1 =    ,   ,   ,   ,   ,CA5,   ,        ; ZQCal Latch
	SDEF ZQLAT2 = CA0,   ,   ,   ,CA4,   ,   ,        ; ZQCal Latch
	SDEF MPC1   =    ,   ,   ,   ,   ,   ,   ,        ; Multi Purpose Command
	SDEF MPC2   =    ,   ,   ,   ,   ,   ,   ,        ; Multi Purpose Command
; -------- For Bank Interleave --------
	SDEF BA0    =      C17
	SDEF BA1    =          C18
	SDEF BA2    =              C19
	SDEF BANK00 =         ,   ,                     ;
	SDEF BANK01 =      BA0,   ,                     ;
	SDEF BANK02 =         ,BA1,                     ;
	SDEF BANK03 =      BA0,BA1,                     ;
	SDEF BANK04 =         ,   ,BA2                  ;
	SDEF BANK05 =      BA0,   ,BA2                  ;
	SDEF BANK06 =         ,BA1,BA2                  ;
	SDEF BANK07 =      BA0,BA1,BA2                  ;
	SDEF BANK_XA=      B<BH      
	SDEF BANK_XB=      B<BD1      
	SDEF BANK_XC=      B<BD2      
	SDEF BANK_XD=      B<BD3      
	SDEF BANK_XE=      B<BD4      
	SDEF BANK_XF=      B<BD5      
	SDEF BANK_XG=      B<BD6      
	SDEF BANK_XH=      B<BD7      
	SDEF BANK_YA=            N_1<NH_1  N_2<NH_2
	SDEF BANK_YB=            N_1<ND1_1 N_2<ND1_2
	SDEF BANK_YC=            N_1<ND2_1 N_2<ND2_2
	SDEF BANK_YD=            N_1<ND3_1 N_2<ND3_2
	SDEF BANK_YE=            N_1<ND4_1 N_2<ND4_2
	SDEF BANK_YF=            N_1<ND5_1 N_2<ND5_2
	SDEF BANK_YG=            N_1<ND6_1 N_2<ND6_2
	SDEF BANK_YH=            N_1<ND7_1 N_2<ND7_2
; -------- For SourceSync --------
	SDEF ENSIG1 = C30
	SDEF ENSIG2 = C31
;--------- For CA Switching --------
	SDEF R1	=	CA0	CA1	CA2	CA3	CA4	CA5
	SDEF R2	=		CA1		CA3		CA5
	SDEF R3 =		CA1		CA3		CA5
	SDEF R4 =
	SDEF R5 =
	SDEF R6 =	CA0		CA2		CA4	
	SDEF R7 = 	CA0		CA2		CA4
	SDEF R8 =	CA0	CA1	CA2	CA3	CA4	CA5

;---------- For DQ Training --------
	SDEF TT =			C23	C24
	SDEF TC =		/D2	C23
	SDEF CT =	/D1			C24
	SDEF CC =	/D1	/D2


	
	ADDRESS DEFINE
		X17-19 = B0-2
		Y17-19 = N0-2
		XY     = ZNBC
	BANK SAVE ADDRESS X17 X18 X19
	BANK LOAD ADDRESS Y17 Y18 Y19

	BURST BLOCK BEGIN(DUMMY_FOR_SOURCESYNC)
		OUT2 = 250MV 220MV
	BURST BLOCK END

