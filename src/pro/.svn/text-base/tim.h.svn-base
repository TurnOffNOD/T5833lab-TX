#ifndef ___Tim_H
#define ___Tim_H
#ifdef __cplusplus
extern "C" {
#endif // __cplusplus

#include <test.h>
#include "Tim.h"
typedef	struct Tim {
	double		tCK    ;
	double		tDQSDQI;
	double		tDQSDQO;
	TgHandle	handle ;
}Tim_t;

inline static void RATE_( Tim_t *tim, int ts, ...)
{
  va_list va;
  double  var;

  va_start(va,ts);
  while(ts > 0) {
    var = va_arg(va, double);
    UTL_AddTgRate( tim->handle, ts, var);
    ts  = va_arg(va, int   );
  }
  va_end(va);
}

inline static void BCLK_( Tim_t *tim, int ts, int n,...)
{
  va_list va;
  double  var;

  va_start(va, n);
  while(ts > 0) {
    var = va_arg(va, double);
    if ( var >= 0.0 ) UTL_AddTgBclk   ( tim->handle, ts, n, var);
    else              UTL_AddTgBclkOff( tim->handle, ts, n     );
    ts  = va_arg(va, int   );
  }
  va_end(va);
}

inline static void CCLK_( Tim_t *tim, int ts, int n,...)
{
  va_list va;
  double  var;

  va_start(va, n);
  while(ts > 0) {
    var = va_arg(va, double);
    if ( var >= 0.0 ) UTL_AddTgCclk   ( tim->handle, ts, n, var);
    else              UTL_AddTgCclkOff( tim->handle, ts, n     );
    ts  = va_arg(va, int   );
  }
  va_end(va);
}

inline static void DREL_( Tim_t *tim, int ts, int n,...)
{
  va_list va;
  double  var;

  va_start(va, n);
  while(ts > 0) {
    var = va_arg(va, double);
    if ( var >= 0.0 ) UTL_AddTgDreL   ( tim->handle, ts, n, var);
    else              UTL_AddTgDreLOff( tim->handle, ts, n     );
    ts  = va_arg(va, int   );
  }
  va_end(va);
}

inline static void DRET_( Tim_t *tim, int ts, int n,...)
{
  va_list va;
  double  var;

  va_start(va, n);
  while(ts > 0) {
    var = va_arg(va, double);
    if ( var >= 0.0 ) UTL_AddTgDreT   ( tim->handle, ts, n, var);
    else              UTL_AddTgDreTOff( tim->handle, ts, n     );
    ts  = va_arg(va, int   );
  }
  va_end(va);
}

inline static void STRB_( Tim_t *tim, int ts, int n,...)
{
  va_list va;
  double  var;

  va_start(va, n);
  while(ts > 0) {
    var = va_arg(va, double);
    if ( var >= 0.0 ) UTL_AddTgStrb   ( tim->handle, ts, n, var);
    else              UTL_AddTgStrbOff( tim->handle, ts, n     );
    ts  = va_arg(va, int   );
  }
  va_end(va);
}

